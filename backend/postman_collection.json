{
  "info": {
    "name": "Recipe Sharing API",
    "description": "Recipe Sharing REST API — recipes, ingredients, and (Week 5) auth + favourites.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001/api" },
    { "key": "token", "value": "" },
    { "key": "recipe_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}/health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}/auth/register"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}/auth/login"] }
          }
        },
        {
          "name": "Get My Favourites",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me/favourites", "host": ["{{base_url}}/auth/me/favourites"] }
          }
        }
      ]
    },
    {
      "name": "Recipes",
      "item": [
        {
          "name": "Get All Recipes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/recipes", "host": ["{{base_url}}/recipes"] }
          }
        },
        {
          "name": "Get Recipes by Cuisine",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/recipes?cuisine=Italian",
              "host": ["{{base_url}}/recipes"],
              "query": [{ "key": "cuisine", "value": "Italian" }]
            }
          }
        },
        {
          "name": "Search Recipes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/recipes?search=pasta",
              "host": ["{{base_url}}/recipes"],
              "query": [{ "key": "search", "value": "pasta" }]
            }
          }
        },
        {
          "name": "Get Cuisines",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/recipes/cuisines", "host": ["{{base_url}}/recipes/cuisines"] }
          }
        },
        {
          "name": "Match Recipes by Ingredients",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ingredients\": [\"garlic\", \"soy sauce\"],\n  \"mode\": \"any\"\n}"
            },
            "url": { "raw": "{{base_url}}/recipes/match", "host": ["{{base_url}}/recipes/match"] }
          }
        },
        {
          "name": "Get Recipe by Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/recipes/{{recipe_id}}",
              "host": ["{{base_url}}/recipes/{{recipe_id}}"]
            }
          }
        },
        {
          "name": "Create Recipe (auth required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Garlic Fried Rice\",\n  \"cuisine\": \"Filipino\",\n  \"cookTime\": 15,\n  \"difficulty\": \"Easy\",\n  \"ingredients\": [\"cooked rice\", \"garlic\", \"soy sauce\"],\n  \"steps\": [\"Fry garlic until golden\", \"Add rice and soy sauce\", \"Stir-fry until heated through\"]\n}"
            },
            "url": { "raw": "{{base_url}}/recipes", "host": ["{{base_url}}/recipes"] }
          }
        },
        {
          "name": "Update Recipe (auth + owner required)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cookTime\": 20\n}"
            },
            "url": {
              "raw": "{{base_url}}/recipes/{{recipe_id}}",
              "host": ["{{base_url}}/recipes/{{recipe_id}}"]
            }
          }
        },
        {
          "name": "Delete Recipe (auth + owner required)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/recipes/{{recipe_id}}",
              "host": ["{{base_url}}/recipes/{{recipe_id}}"]
            }
          }
        },
        {
          "name": "Toggle Favourite (auth required)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/recipes/{{recipe_id}}/favourite",
              "host": ["{{base_url}}/recipes/{{recipe_id}}/favourite"]
            }
          }
        }
      ]
    },
    {
      "name": "Ingredients",
      "item": [
        {
          "name": "Get All Ingredients",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/ingredients", "host": ["{{base_url}}/ingredients"] }
          }
        }
      ]
    }
  ]
}
